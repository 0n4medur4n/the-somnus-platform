{
  "name": "the-somnus-platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The Somnus platform monorepo. See THE_SOMNUS_PLATFORM_BUILD_PLAN.md.",
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "check": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.build.json",
    "ci": "pnpm run lint && pnpm run typecheck && pnpm run test:run && pnpm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@types/node": "24.10.1",
    "@vitest/coverage-v8": "4.1.10",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}
