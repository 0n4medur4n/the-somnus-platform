# Normalize line endings for cross-platform contributors.
# Source code: LF, checked-out as LF.
# Windows-only batch/shell scripts: CRLF on checkout, LF in the repo.
# Markdown, JSON, YAML, etc.: LF (matches .editorconfig).

*                 text=auto eol=lf

*.bat             text eol=crlf
*.cmd             text eol=crlf
*.ps1             text eol=lf

*.md              text eol=lf
*.yml             text eol=lf
*.yaml            text eol=lf
*.json            text eol=lf
*.ts              text eol=lf
*.tsx             text eol=lf
*.js              text eol=lf
*.cjs             text eol=lf
*.mjs             text eol=lf
*.css             text eol=lf
*.html            text eol=lf

# Binary assets stay untouched.
*.png             binary
*.jpg             binary
*.jpeg            binary
*.gif             binary
*.webp            binary
*.ico             binary
*.svg             text eol=lf
*.woff            binary
*.woff2           binary

# GitHub language detection hints.
docs/**/*.md      linguist-documentation
infrastructure/** linguist-ignored
schemas/openapi/** linguist-generated
